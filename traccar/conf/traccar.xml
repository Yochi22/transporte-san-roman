<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE properties SYSTEM "http://java.sun.com/dtd/properties.dtd">
<properties>
    <entry key="config.default">./conf/default.xml</entry>
    <entry key="web.port">8082</entry>

    <!-- Base de datos embebida H2 (no requiere instalacion externa) -->
    <entry key="database.driver">org.h2.Driver</entry>
    <entry key="database.url">jdbc:h2:./data/database</entry>
    <entry key="database.user">sa</entry>
    <entry key="database.password"></entry>

    <!-- Puertos TCP de protocolos GPS usados en pruebas -->
    <entry key="gps103.port">5001</entry>
    <entry key="coban.port">5002</entry>

    <!-- Reenvio JSON al backend si controlas esta instancia -->
    <entry key="forward.enable">true</entry>
    <entry key="forward.type">json</entry>
    <entry key="forward.url">https://TU_BACKEND/api/gps/positions?token=TU_GPS_WEBHOOK_TOKEN</entry>
</properties>
