generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Rol {
  ADMIN
  OPERACIONES
}

enum EstadoCamion {
  DISPONIBLE
  EN_RUTA
  EN_TALLER
}

enum TipoVehiculo {
  NPR
  TORONTO
  FURGON
  CHUTO
  CORTINERO
  BATEA
}

enum EstadoChofer {
  DISPONIBLE
  EN_RUTA
  DESCANSO
}

enum EstadoLogistico {
  PENDIENTE
  EN_CURSO
  COMPLETADO
}

enum EstadoFinanciero {
  PENDIENTE
  LIQUIDADO
}

enum TipoParada {
  CARGA
  DESCARGA
  PERNOCTA
}

enum EstadoParada {
  PENDIENTE
  EN_CURSO
  COMPLETADA
}

enum TipoReporte {
  CARGANDO
  EN_RUTA
  EN_PERNOCTA
  DESCARGADO
  ESPERANDO_INSTRUCCIONES
  LIBRE
  NOVEDAD
  OTRO
}

enum TipoGasto {
  COMBUSTIBLE
  PEAJE
  COMIDA
  HOSPEDAJE
  REPARACION
  OTRO
}

enum OrigenGasto {
  CHOFER
  ADMIN
}

enum TipoMantenimiento {
  REPARACION
  CAMBIO_ACEITE
  CAUCHOS
  FRENOS
  BATERIA
  REVISION
  OTRO
}

enum EstadoMantenimiento {
  EN_PROCESO
  COMPLETADO
}

enum EstadoMotor {
  ENCENDIDO
  APAGADO
}

enum TipoEventoCombustible {
  CARGA
  TRANSFERENCIA_SALIDA
  TRANSFERENCIA_ENTRADA
  AJUSTE
  PERDIDA
}

model Usuario {
  id             String   @id @default(uuid())
  nombre         String
  email          String   @unique
  passwordHash   String   @map("password_hash")
  rol            Rol      @default(OPERACIONES)
  activo         Boolean  @default(true)
  sessionVersion Int      @default(0) @map("session_version")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  viajesCreados Viaje[] @relation("ViajeCreador")

  @@map("usuarios")
}

model Chofer {
  id                String          @id @default(uuid())
  nombre            String
  cedula            String          @unique
  telefono          String          @unique
  whatsappChatId    String?         @unique @map("whatsapp_chat_id")
  estado            EstadoChofer    @default(DISPONIBLE)
  ubicacionActual   String?         @default("Sede") @map("ubicacion_actual")
  ultimoReporteAt   DateTime?       @map("ultimo_reporte_at")
  activo            Boolean         @default(true)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  viajes            Viaje[]
  reportes          ReporteChofer[]
  gastos            Gasto[]
  unidadesAsignadas ChoferUnidad[]
  eventosCombustible CombustibleEvento[]

  @@index([estado, activo])
  @@map("choferes")
}

model Camion {
  id                String                  @id @default(uuid())
  placa             String                  @unique
  gpsImei           String?                 @unique @map("gps_imei")
  tipoVehiculo      TipoVehiculo            @default(NPR) @map("tipo_vehiculo")
  placaFurgon       String?                 @unique @map("placa_furgon")
  placaChuto        String?                 @unique @map("placa_chuto")
  marcaModelo       String                  @map("marca_modelo")
  estado            EstadoCamion            @default(DISPONIBLE)
  ubicacionActual   String?                 @default("Sede") @map("ubicacion_actual")
  motivoTaller      String?                 @map("motivo_taller")
  capacidadTanqueLitros Decimal?            @map("capacidad_tanque_litros")
  rendimientoEsperadoKmL Decimal?           @map("rendimiento_esperado_km_l")
  toleranciaCombustiblePct Decimal?         @default(10) @map("tolerancia_combustible_pct")
  activo            Boolean                 @default(true)
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  viajes            Viaje[]
  viajesAsignados   ViajeUnidad[]
  mantenimientos    MantenimientoVehiculo[]
  posicionGps       TruckPosition?
  choferesAsignados ChoferUnidad[]
  eventosCombustible CombustibleEvento[]
  estandaresCombustible CombustibleEstandarRuta[]

  @@index([estado, activo])
  @@map("camiones")
}

model ChoferUnidad {
  id        String   @id @default(uuid())
  choferId  String   @map("chofer_id")
  camionId  String   @map("camion_id")
  createdAt DateTime @default(now()) @map("created_at")

  chofer Chofer @relation(fields: [choferId], references: [id])
  camion Camion @relation(fields: [camionId], references: [id])

  @@unique([choferId, camionId])
  @@unique([camionId])
  @@index([camionId])
  @@map("choferes_unidades")
}

model TruckPosition {
  id           String       @id @default(uuid())
  truckId      String       @unique @map("truck_id")
  latitude     Float
  longitude    Float
  speed        Float        @default(0)
  engineStatus EstadoMotor? @map("engine_status")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  camion Camion @relation(fields: [truckId], references: [id])

  @@index([updatedAt])
  @@map("truck_positions")
}

model MantenimientoVehiculo {
  id           String              @id @default(uuid())
  camionId     String              @map("camion_id")
  tipo         TipoMantenimiento
  estado       EstadoMantenimiento @default(EN_PROCESO)
  falla        String
  descripcion  String?
  kilometraje  Int?
  costo        Decimal             @default(0)
  fechaIngreso DateTime            @default(now()) @map("fecha_ingreso")
  fechaSalida  DateTime?           @map("fecha_salida")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  camion Camion @relation(fields: [camionId], references: [id])

  @@index([camionId, fechaIngreso])
  @@index([estado])
  @@map("mantenimientos_vehiculos")
}

model Viaje {
  id                    String           @id @default(uuid())
  codigo                String           @unique
  camionId              String           @map("camion_id")
  choferId              String           @map("chofer_id")
  creadoPorId           String           @map("creado_por_id")
  estadoLogistico       EstadoLogistico  @default(PENDIENTE) @map("estado_logistico")
  estadoFinanciero      EstadoFinanciero @default(PENDIENTE) @map("estado_financiero")
  documentacionRecibida Boolean          @default(false) @map("documentacion_recibida")
  numeroGuia            String?          @unique @map("numero_guia")
  viaticosDepositados   Decimal          @default(0) @map("viaticos_depositados")
  viaticosGastados      Decimal          @default(0) @map("viaticos_gastados")
  honorariosChofer      Decimal          @default(0) @map("honorarios_chofer")
  odometroInicial       Int?             @map("odometro_inicial")
  odometroFinal         Int?             @map("odometro_final")
  combustibleInicial    Decimal?         @map("combustible_inicial")
  combustibleFinal      Decimal?         @map("combustible_final")
  fechaLiquidacion      DateTime?        @map("fecha_liquidacion")
  observaciones         String?
  fechaInicio           DateTime?        @map("fecha_inicio")
  fechaCierre           DateTime?        @map("fecha_cierre")
  createdAt             DateTime         @default(now()) @map("created_at")
  updatedAt             DateTime         @updatedAt @map("updated_at")

  camion    Camion          @relation(fields: [camionId], references: [id])
  chofer    Chofer          @relation(fields: [choferId], references: [id])
  creadoPor Usuario         @relation("ViajeCreador", fields: [creadoPorId], references: [id])
  paradas   Parada[]
  reportes  ReporteChofer[]
  gastos    Gasto[]
  unidades  ViajeUnidad[]
  combustibleEventos CombustibleEvento[]

  @@index([estadoLogistico, estadoFinanciero])
  @@index([camionId, estadoLogistico])
  @@index([choferId, estadoLogistico])
  @@index([createdAt])
  @@map("viajes")
}

model CombustibleEvento {
  id          String                 @id @default(uuid())
  viajeId     String                 @map("viaje_id")
  choferId    String                 @map("chofer_id")
  camionId    String                 @map("camion_id")
  tipo        TipoEventoCombustible
  litros      Decimal
  monto       Decimal                @default(0)
  moneda      String                 @default("USD")
  tasaBcv     Decimal?               @map("tasa_bcv")
  ubicacion   String?
  descripcion String?
  createdAt   DateTime               @default(now()) @map("created_at")

  viaje  Viaje  @relation(fields: [viajeId], references: [id], onDelete: Cascade)
  chofer Chofer @relation(fields: [choferId], references: [id], onDelete: Cascade)
  camion Camion @relation(fields: [camionId], references: [id], onDelete: Cascade)

  @@index([viajeId, createdAt])
  @@index([choferId, createdAt])
  @@index([camionId, createdAt])
  @@map("combustible_eventos")
}

model CombustibleEstandarRuta {
  id            String       @id @default(uuid())
  origen        String
  destino       String
  tipoVehiculo  TipoVehiculo? @map("tipo_vehiculo")
  camionId      String?       @map("camion_id")
  litrosEsperados Decimal     @map("litros_esperados")
  toleranciaPct Decimal       @default(10) @map("tolerancia_pct")
  activo        Boolean       @default(true)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  camion Camion? @relation(fields: [camionId], references: [id], onDelete: SetNull)

  @@index([origen, destino, activo])
  @@index([camionId])
  @@map("combustible_estandares_ruta")
}

model ViajeUnidad {
  id        String   @id @default(uuid())
  viajeId   String   @map("viaje_id")
  camionId  String   @map("camion_id")
  createdAt DateTime @default(now()) @map("created_at")

  viaje  Viaje  @relation(fields: [viajeId], references: [id])
  camion Camion @relation(fields: [camionId], references: [id])

  @@unique([viajeId, camionId])
  @@index([camionId])
  @@map("viajes_unidades")
}

model Parada {
  id                String       @id @default(uuid())
  viajeId           String       @map("viaje_id")
  orden             Int
  tramo             Int          @default(1)
  tipo              TipoParada
  lugar             String
  ciudad            String
  descripcionCarga  String?      @map("descripcion_carga")
  fechaProgramada   DateTime?    @map("fecha_programada")
  cargarAlDescargar Boolean      @default(false) @map("cargar_al_descargar")
  estado            EstadoParada @default(PENDIENTE)
  comprobanteUrl    String?      @map("comprobante_url")
  completadaAt      DateTime?    @map("completada_at")
  createdAt         DateTime     @default(now()) @map("created_at")

  viaje    Viaje           @relation(fields: [viajeId], references: [id])
  reportes ReporteChofer[]

  @@index([viajeId, orden])
  @@index([estado])
  @@map("paradas")
}

model ReporteChofer {
  id              String      @id @default(uuid())
  viajeId         String      @map("viaje_id")
  choferId        String      @map("chofer_id")
  paradaId        String?     @map("parada_id")
  mensajeOriginal String      @map("mensaje_original")
  tipoReporte     TipoReporte @map("tipo_reporte")
  ubicacion       String?
  procesadoPorIa  String?     @map("procesado_por_ia")
  createdAt       DateTime    @default(now()) @map("created_at")

  viaje  Viaje   @relation(fields: [viajeId], references: [id])
  chofer Chofer  @relation(fields: [choferId], references: [id])
  parada Parada? @relation(fields: [paradaId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([viajeId, createdAt])
  @@index([choferId, createdAt])
  @@map("reportes_chofer")
}

model Gasto {
  id             String      @id @default(uuid())
  viajeId        String      @map("viaje_id")
  choferId       String      @map("chofer_id")
  tipo           TipoGasto
  origen         OrigenGasto @default(ADMIN)
  monto          Decimal
  descripcion    String?
  comprobanteUrl String?     @map("comprobante_url")
  createdAt      DateTime    @default(now()) @map("created_at")

  viaje  Viaje  @relation(fields: [viajeId], references: [id])
  chofer Chofer @relation(fields: [choferId], references: [id])

  @@index([viajeId, createdAt])
  @@index([choferId, createdAt])
  @@map("gastos")
}
